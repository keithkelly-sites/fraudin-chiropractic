---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mapImg from '../assets/images/map.png';
---
<Layout title="Contact | Fraudin Advanced Chiropractic & Rehab" description="Contact Fraudin Chiropractic. Call 412-257-8090. 1030 Boyce Road, Pittsburgh, PA 15241. New patients welcome.">
  <section class="page-hero"><div class="container">
    <span class="label reveal">Contact</span>
    <h1 class="ph__title reveal">Make an <em>appointment.</em></h1>
    <p class="ph__sub reveal reveal--delay-1">Call to schedule or fill out the form below. New patients always welcome.</p>
  </div></section>

  <section class="contact section"><div class="container"><div class="contact__grid">
    <div class="contact__info">
      <div class="cb reveal"><h2 class="cb__label">Phone</h2><a href="tel:4122578090" class="cb__phone">412-257-8090</a></div>
      <div class="cb reveal reveal--delay-1"><h2 class="cb__label">Email</h2><a href="mailto:fraudinchiropractic@gmail.com" style="color: var(--color-accent); font-size: var(--font-size-sm); text-decoration: underline; text-underline-offset: 3px;">fraudinchiropractic@gmail.com</a></div>
      <div class="cb reveal reveal--delay-2"><h2 class="cb__label">Address</h2><address style="font-style: normal; color: var(--color-text); line-height: 1.7;">1030 Boyce Road<br />Pittsburgh, PA 15241</address></div>
      <div class="cb reveal reveal--delay-3"><h2 class="cb__label">Hours</h2>
        <div class="cb__hours">
          <div><span>Mon, Wed, Thu</span><span>8:30-11:30am, 2:00-6:00pm</span></div>
          <div><span>Tue</span><span>8:30-11:30am, 2:00-4:30pm</span></div>
          <div><span>Fri</span><span>8:30-11:30am</span></div>
          <div><span>Sat-Sun</span><span>Closed</span></div>
        </div>
      </div>
    </div>
    <div class="contact__map reveal">
      <a href="https://www.google.com/maps/dir/?api=1&destination=1030+Boyce+Road+Pittsburgh+PA+15241" target="_blank" rel="noopener noreferrer" class="map-card">
        <Image src={mapImg} alt="Map showing Fraudin Chiropractic at 1030 Boyce Road, Pittsburgh" loading="lazy" width={800} height={500} layout="constrained" class="map-card__img" />
        <div class="map-card__bar"><span>1030 Boyce Road, Pittsburgh</span><span>Get directions &rarr;</span></div>
      </a>
    </div>
  </div></div></section>

  <section class="form-section section"><div class="container container--narrow">
    <span class="label reveal">Request appointment</span>
    <h2 class="reveal" style="margin-top: var(--space-sm); margin-bottom: var(--space-lg);">Send us a <em style="color: var(--color-accent); font-style: italic;">message.</em></h2>
    <form action="#" method="POST" class="form reveal reveal--delay-1">
      <div class="form__row"><div class="form__field"><label for="name">Name</label><input type="text" id="name" name="name" required autocomplete="name" /></div><div class="form__field"><label for="phone">Phone</label><input type="tel" id="phone" name="phone" required autocomplete="tel" /></div></div>
      <div class="form__field"><label for="email">Email</label><input type="email" id="email" name="email" autocomplete="email" /></div>
      <div class="form__field"><label for="message">How can we help?</label><textarea id="message" name="message" rows="4" required></textarea></div>
      <button type="submit" class="btn btn--primary">Send message</button>
    </form>
  </div></section>
</Layout>
<style>
  .page-hero { padding: var(--space-2xl) 0 var(--space-xl); border-bottom: 1px solid var(--color-border); background: var(--color-bg-warm); }
  .ph__title { font-size: var(--font-size-3xl); margin-top: var(--space-sm); margin-bottom: var(--space-md); }
  .ph__title em { color: var(--color-accent); font-style: italic; }
  .ph__sub { font-size: var(--font-size-md); color: var(--color-text-muted); max-width: 50ch; line-height: 1.6; }
  .contact__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); }
  @media (min-width: 768px) { .contact__grid { grid-template-columns: 5fr 7fr; gap: var(--space-2xl); } }
  .contact__info { display: flex; flex-direction: column; gap: var(--space-xl); }
  .cb__label { font-family: var(--font-body); font-size: var(--font-size-xs); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-faint); margin-bottom: var(--space-sm); }
  .cb__phone { display: block; font-family: var(--font-display); font-size: var(--font-size-xl); font-weight: 700; color: var(--color-accent); text-decoration: none; }
  .cb__hours { display: flex; flex-direction: column; gap: var(--space-xs); }
  .cb__hours > div { display: flex; justify-content: space-between; gap: 1rem; font-size: var(--font-size-sm); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-border); }
  .cb__hours > div:last-child { border-bottom: none; }
  .cb__hours span:first-child { color: var(--color-text-muted); font-weight: 500; }
  .cb__hours span:last-child { color: var(--color-text-faint); }
  .map-card { display: block; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-border); transition: border-color var(--duration-normal); }
  .map-card:hover { border-color: var(--color-accent); }
  .map-card__img { width: 100%; height: auto; display: block; }
  .map-card__bar { display: flex; justify-content: space-between; align-items: center; padding: var(--space-md); background: var(--color-bg-warm); font-size: var(--font-size-sm); color: var(--color-text-muted); }
  .map-card__bar span:last-child { color: var(--color-accent); font-weight: 600; }
  .form-section { background: var(--color-bg-warm); }
  .form { display: flex; flex-direction: column; gap: var(--space-md); }
  .form__row { display: grid; grid-template-columns: 1fr; gap: var(--space-md); }
  @media (min-width: 600px) { .form__row { grid-template-columns: 1fr 1fr; } }
  .form__field { display: flex; flex-direction: column; gap: var(--space-xs); }
  .form__field label { font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text-muted); }
  .form__field input, .form__field textarea { padding: 0.75rem 1rem; background: var(--color-bg-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); color: var(--color-text); font-size: var(--font-size-base); transition: border-color var(--duration-fast); }
  .form__field input:focus, .form__field textarea:focus { border-color: var(--color-accent); outline: none; }
  .form__field textarea { resize: vertical; min-height: 100px; }
</style>
