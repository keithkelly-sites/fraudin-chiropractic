---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = "Fraudin Advanced Chiropractic & Rehab — chiropractic care, sports medicine, and rehabilitation in Pittsburgh, PA. Father-son practice since 1982." } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = "https://fraudin-chiropractic.keithkelly.dev";
const canonicalUrl = `${siteUrl}${currentPath === '/' ? '' : currentPath.replace(/\/$/, '')}`;
const ogImage = `${siteUrl}/favicon.png`;
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const jsonLd = currentPath === '/' ? JSON.stringify({
  "@context": "https://schema.org", "@type": "Chiropractor",
  "name": "Fraudin Advanced Chiropractic & Rehab", "url": siteUrl, "telephone": "412-257-8090",
  "email": "fraudinchiropractic@gmail.com", "image": ogImage,
  "address": { "@type": "PostalAddress", "streetAddress": "1030 Boyce Road", "addressLocality": "Pittsburgh", "addressRegion": "PA", "postalCode": "15241", "addressCountry": "US" },
  "geo": { "@type": "GeoCoordinates", "latitude": 40.3322, "longitude": -80.0769 },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Wednesday","Thursday"], "opens": "08:30", "closes": "11:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Wednesday","Thursday"], "opens": "14:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:30", "closes": "11:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "14:00", "closes": "16:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "08:30", "closes": "11:30" }
  ],
  "sameAs": [], "priceRange": "$$"
}) : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title><meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} /><link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content={title} /><meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} /><meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} /><meta property="og:site_name" content="Fraudin Advanced Chiropractic & Rehab" />
    <Font cssVariable="--font-body" preload /><Font cssVariable="--font-display" preload />
    <ClientRouter />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo">
          <span class="site-header__logo-name">Fraudin Chiropractic</span>
          <span class="site-header__logo-tag">Advanced Chiropractic & Rehab</span>
        </a>
        <nav class="site-header__nav" aria-label="Main navigation">
          {navLinks.map(link => <a href={link.href} aria-current={currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href)) ? "page" : undefined}>{link.label}</a>)}
        </nav>
        <a href="tel:4122578090" class="site-header__cta" aria-label="Call Fraudin Chiropractic at 412-257-8090">412-257-8090</a>
        <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"><span></span><span></span><span></span></button>
      </div>
    </header>
    <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation">
      {navLinks.map(link => <a href={link.href}>{link.label}</a>)}
      <a href="tel:4122578090" class="mobile-menu__phone">412-257-8090</a>
    </nav>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__grid">
          <div class="site-footer__brand">
            <span class="site-footer__brand-name">Fraudin Advanced Chiropractic & Rehab</span>
            <p>Father-son chiropractic practice serving Pittsburgh since 1982. Board certified in rehabilitation.</p>
            <address class="site-footer__address"><a href="tel:4122578090">412-257-8090</a><br />1030 Boyce Road<br />Pittsburgh, PA 15241</address>
          </div>
          <div>
            <h3 class="site-footer__heading">Pages</h3>
            <nav class="site-footer__links" aria-label="Footer navigation">
              <a href="/">Home</a><a href="/services">Services</a><a href="/about">About</a><a href="/contact">Contact</a>
            </nav>
          </div>
          <div>
            <h3 class="site-footer__heading">Hours</h3>
            <div class="site-footer__hours">
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Mon</span><span>8:30-11:30am, 2:00-6:00pm</span></div>
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Tue</span><span>8:30-11:30am, 2:00-4:30pm</span></div>
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Wed</span><span>8:30-11:30am, 2:00-6:00pm</span></div>
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Thu</span><span>8:30-11:30am, 2:00-6:00pm</span></div>
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Fri</span><span>8:30-11:30am</span></div>
              <div class="site-footer__hours-row"><span class="site-footer__hours-day">Sat-Sun</span><span>Closed</span></div>
            </div>
          </div>
        </div>
        <div class="site-footer__bottom">
          <span>&copy; {new Date().getFullYear()} Fraudin Advanced Chiropractic & Rehab. All rights reserved.</span>
        </div>
      </div>
    </footer>
    <script>
      document.documentElement.classList.add('js-ready');
      document.addEventListener('astro:page-load', () => {
        const toggle = document.querySelector('.mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (toggle && menu) {
          menu.classList.remove('is-open'); toggle.setAttribute('aria-expanded', 'false'); document.body.style.overflow = '';
          const nt = toggle.cloneNode(true) as HTMLElement; toggle.parentNode?.replaceChild(nt, toggle);
          nt.addEventListener('click', () => { const o = menu.classList.contains('is-open'); menu.classList.toggle('is-open'); nt.setAttribute('aria-expanded', String(!o)); document.body.style.overflow = o ? '' : 'hidden'; });
          menu.querySelectorAll('a').forEach(l => { l.addEventListener('click', () => { menu.classList.remove('is-open'); nt.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; }); });
        }
        const obs = new IntersectionObserver((es) => { es.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }); }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(el => { el.classList.add('reveal--ready'); obs.observe(el); });
      });
    </script>
  </body>
</html>
